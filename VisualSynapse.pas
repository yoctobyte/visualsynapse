      {$IFDEF OCX}
        (TPanel)
      {$ELSE}
        {$IFDEF BAREOBJECT}
          (TObject)
        {$ELSE} //no switch is default delphi component
         (TComponent)
        {$ENDIF}
      {$ENDIF}
    private
      FJobs:TList; //always encapsulate access by critical section FCS
    protected
      FInfo:THostInfo;
      FSocksProxyInfo:TSocksProxyInfo;
      FQuery:String;
      FData:String;
      FThreads:TList; //TVisualThread;
      FAutoTLS:Boolean;
