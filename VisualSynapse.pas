    Exit;
  U:=TUDPRequest.Create;
  if Value then
    begin
      if FBindPort='' then
        FBindPort := '0';
      if FBindAdapter = '' then
        FBindAdapter := '0.0.0.0';
      U.BindPort := FBindPort;
      U.BindAdapter := FBindAdapter;
    end
  else
    begin
      U.CloseSocket := True;
    end;
  Enqueue (U);
