    end;

    TSocksInfo = record
      IP,
      Port,
      Username,
      Password:String;
      Timeout:Integer;
      Resolver:Boolean;
      SocksType:TSocksType;
    end;

    TVisualSynapse = class;
    TVisualThread = class;
    TSocksProxyInfo = class;

    TOnVisualData = procedure (Sender:TVisualSynapse; Handle:Integer; Data:String; Query:String; From:THostInfo) of Object;
    TOnDataStrings = procedure (Sender:TVisualSynapse; Handle:Integer; Data:TStrings; Query:String; From:THostInfo) of Object;
    TOnError = procedure (Sender:TVisualSynapse; Handle:Integer; Query:String; ErrorCode:Integer; ErrorMessage:String) of Object;
    TOnProgress = procedure (Sender:TVisualSynapse; Handle:Integer; Reason:THookReason; Value:String; Sock: TSynapseSocket; var Continue:Boolean) of Object;
    TOnSockStatus = procedure (Sender:TVisualSynapse; Handle:Integer; Value:String) of Object;
    TOnSockInteger = procedure (Sender:TVisualSynapse; Handle:Integer; Value:Integer) of Object;

    TJobType=(jtCreateNew, jtControl);

    TJob = class (TObject)
      Handle:Integer;
      SendBandwidth: Integer;
      RecvBandWidth: Integer;
